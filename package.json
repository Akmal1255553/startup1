{
  "name": "return-guard-ai",
  "private": true,
  "scripts": {
    "build": "remix vite:build",
    "vercel-build": "prisma generate --schema prisma-postgres/schema.prisma && npm run build",
    "db:migrate:prod": "prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "dev": "shopify app dev --store store-fbugaeho.myshopify.com",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "npm run setup:dev",
    "setup:dev": "prisma generate && prisma migrate deploy",
    "setup:prod": "prisma generate --schema prisma-postgres/schema.prisma && prisma migrate deploy --schema prisma-postgres/schema.prisma",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite"
  },
